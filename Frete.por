programa {
  funcao inicio() { real peso = 2 real distancia = 0.05 real volume = 10 real frete = 15
  real total = 20 * peso + 650 * distancia + volume * 1 + frete, total2 = 3 * peso + 1200 * distancia + volume * 0.2 + frete, total3 = 60 * peso + 1000 * distancia + volume * 0.5 + frete
  
  escreva(total)
  escreva("\n")
  escreva(total2)
  escreva("\n")
  escreva(total3)



  }
}
