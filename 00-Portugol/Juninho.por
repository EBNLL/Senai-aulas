programa {
  funcao inicio() { real salario, diasTrabalhados

  escreva("Quantos dias Juninho trabalhou esse mês: ")
  leia(diasTrabalhados)
  escreva("Escreva quanto o Juninho ganha por mês: ")
  leia(salario)
  inteiro valorPorDia = salario / diasTrabalhados
  escreva("Juninho recebe R$" + valorPorDia + " por dia")
    
  }
}
