programa {
  funcao inicio() { real dizimo, contas

   escreva("Quanto a igreja recebeu de dizimo esse mês? ")
   leia(dizimo)
   
   escreva("Quanto a igreja gastou esse mês? ")
   leia(contas)
  
   real quantoSobrou = dizimo - contas
   escreva("Sobrou R$" + quantoSobrou + " depois de pagar todas as contas da igreja")
   


    
  }
}
